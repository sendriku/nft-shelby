# ============================================================
# Shelby NFT Storage — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Aptos Labs API Key (get from: https://developers.aptoslabs.com/)
# Required for: Aptos Indexer, AptosWalletAdapterProvider
NEXT_PUBLIC_APTOS_API_KEY=aptoslabs_xxxxxxxxxxxxxxxxxxxxxxxx

# Shelby Protocol API Key (get from: https://developers.shelby.xyz/)
# Required for: ShelbyClient initialization, RPC upload
NEXT_PUBLIC_SHELBY_API_KEY=aptoslabs_xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Network URLs (Testnet — pre-configured, do not change)
# ============================================================
# NEXT_PUBLIC_APTOS_RPC=https://api.testnet.aptoslabs.com/v1
# NEXT_PUBLIC_SHELBY_RPC=https://api.testnet.shelby.xyz/shelby
# NEXT_PUBLIC_APTOS_INDEXER=https://api.testnet.aptoslabs.com/v1/graphql
